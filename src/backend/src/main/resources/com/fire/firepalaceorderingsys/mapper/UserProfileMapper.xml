<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fire.firepalaceorderingsys.mapper.UserProfileMapper">
    <!-- 如果需要复杂的SQL查询，可以在这里添加 -->
    
    <!-- 结果映射配置 -->
    <resultMap id="UserProfileResultMap" type="com.fire.firepalaceorderingsys.pojo.UserProfile">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="avgSpend" column="avg_spend" />
        <result property="favoriteCategory" column="favorite_category" />
        <result property="spicyPreference" column="spicy_preference" />
        <result property="sweetPreference" column="sweet_preference" />
        <result property="saltyPreference" column="salty_preference" />
        <result property="oilPreference" column="oil_preference" />
        <result property="allergyIngredients" column="allergy_ingredients" />
        <result property="dietaryRestrictions" column="dietary_restrictions" />
        <result property="frequentDishes" column="frequent_dishes" />
        <result property="visitCount" column="visit_count" />
        <result property="lastVisitTime" column="last_visit_time" />
        <result property="nativePlace" column="native_place" />
        <result property="preference" column="preference" />
    </resultMap>

</mapper>
